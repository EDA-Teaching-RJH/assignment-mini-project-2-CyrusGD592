def deal_value(dealer): # same function for player hand but for dealer
   deal_total = 0 
   deal_aces = 0 
   for i in dealer:  
      rank = i[0]
      deal_total += value.get(rank, 0)
      if "Ace" in rank: 
         deal_aces += 1 
   while deal_total > 21 and deal_aces > 0: 
      deal_total -= 10 
      deal_aces -= 1 
   return deal_total


